{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://insitututor.local/schemas/learning_event_v1.schema.json",
  "title": "LearningEventV1",
  "type": "object",
  "required": ["event_id", "event_type", "session_id", "scope", "time_range_sec", "evidence", "diagnosis"],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "event_type": { "type": "string", "enum": ["confusion", "error"] },
    "session_id": { "type": "string", "minLength": 1 },
    "scope": { "$ref": "#/$defs/scope" },
    "time_range_sec": { "$ref": "#/$defs/time_range_sec" },
    "evidence": {
      "type": "object",
      "properties": {
        "student_utterances": { "type": "array", "items": { "type": "object" } },
        "teacher_utterances": { "type": "array", "items": { "type": "object" } },
        "video_observation": { "type": "string" },
        "system_prompt_at_time": { "type": "string" },
        "detector_state": { "type": "object" }
      },
      "additionalProperties": true
    },
    "diagnosis": {
      "type": "object",
      "required": ["what_happened", "why_it_happened", "confidence"],
      "properties": {
        "what_happened": { "type": "string" },
        "why_it_happened": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": true
    },
    "proposed_actions": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": true,
  "$defs": {
    "time_range_sec": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "number", "minimum": 0 },
        "end": { "type": "number", "minimum": 0 }
      }
    },
    "scope": {
      "type": "object",
      "required": ["applies_to_sections", "applies_to_steps"],
      "properties": {
        "applies_to_sections": { "type": "array", "items": { "type": "string" } },
        "applies_to_steps": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  }
}
