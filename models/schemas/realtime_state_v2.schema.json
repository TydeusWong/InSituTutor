{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://insitututor.local/schemas/realtime_state_v2.schema.json",
  "title": "RealtimeStateV2",
  "type": "object",
  "required": ["session_id", "current_section", "current_step", "last_passed_step", "latency_ms"],
  "properties": {
    "session_id": {"type": "string"},
    "current_section": {"type": "string"},
    "current_step": {"type": "string"},
    "active_error": {"type": ["string", "null"]},
    "last_passed_step": {"type": "string"},
    "latency_ms": {"type": "number", "minimum": 0}
  }
}
